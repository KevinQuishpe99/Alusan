# Copiar a .env (local) o pegar en Render → Environment
# Renombrar: cp .env.example .env

PORT=3001
NODE_ENV=production

PERSEO_API_KEY=tu_api_key_perseo
API_KEY=tu_api_key_perseo
API_BASE_URL=https://accesoalnusan.app/api
ALMACEN_ID=2

CACHE_TTL_CATEGORIAS=21600
CACHE_TTL_PRODUCTOS=14400
CACHE_CONTROL_PRODUCTOS=60

# true = siempre incluir imágenes (1 por variante por defecto); false solo si falta RAM
DEFAULT_INCLUIR_IMAGENES=true
DEFAULT_MAX_IMAGENES=1
DEFAULT_TARIFAS_RESUMIDAS=true

MAX_IMAGE_SIZE=120
IMAGE_QUALITY=38
COMPRESSION_EFFORT=6
MAX_OUTPUT_BYTES=18000
IMAGE_EMERGENCY_SIZE=72
IMAGE_EMERGENCY_QUALITY=28
MAX_IMAGE_RESPONSE_BYTES=3145728

MAX_CONCURRENT_REQUESTS=4
MAX_CONCURRENT_COMPRESSION=2
MAX_CONCURRENT_EXISTENCIAS=6
HIDRATACION_BATCH_SIZE=4
EXISTENCIAS_BATCH_SIZE=12
COMPRESSION_BATCH_SIZE=4

IMAGE_REQUEST_TIMEOUT=10000
PRODUCTOS_CONSULTA_TIMEOUT=60000

LOG_VERBOSE=false
